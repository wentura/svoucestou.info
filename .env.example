# Zkopírujte do .env.local a doplňte hodnoty.

RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM="Svou Cestou <kontakt@vasadomena.cz>"

# Příjemce zpráv z kontaktního formuláře.
# Dokud v Resend NEMÁTE ověřenou doménu, smíte posílat jen na e-mail účtu Resend:
# CONTACT_TO_EMAIL=vas.email@gmail.com
# Po ověření domény na https://resend.com/domains můžete např.:
# CONTACT_TO_EMAIL=info@zbyneksvoboda.cz
CONTACT_TO_EMAIL=info@zbyneksvoboda.cz
