# Zkopírujte do .env.local a doplňte hodnoty.

RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM="Svou Cestou <kontakt@vasadomena.cz>"

# Příjemce zpráv z kontaktního formuláře.
# Musí odpovídat SITE.contactEmail v lib/site-config.js.
CONTACT_TO_EMAIL=info@svoucestou.info

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x00000000000000000000AA
TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000AA
